#!/usr/bin/env python3
"""
LLM 对话节点 (多模态语义控制版)

链路：
    ASR识别 -> /asr_result -> LLM理解语义 -> 执行命令(移动/VLM/传感器/导航) + TTS播报
"""
import re            # 正则表达式，用于解析 XML 风格标签（<move>/<vlm>/<sensor>/<nav>）
import math           # 数学常数（pi, tau 等）
import json          # JSON 解析（robot_state、地点持久化）
import os            # 文件操作（地点持久化）
import time          # 时间工具（ASR防抖等）
import threading     # 线程库（异步执行 LLM/导航等耗时操作）
import requests      # HTTP 请求库，用于调用 LLM 的 OpenAI 兼容 API
import rclpy         # ROS2 Python 客户端库
from rclpy.node import Node                          # ROS2 节点基类
from std_msgs.msg import String                       # 标准字符串消息，接收 ASR 识别结果
from std_msgs.msg import Float32MultiArray              # 浮点数组消息，接收温湿度传感器数据
from gm_car_interfaces.msg import RobotStatus     # 自定义消息：小车状态（电池/位姿等）
from geometry_msgs.msg import Twist                   # 速度消息（线速度 + 角速度），用于控车
from geometry_msgs.msg import PoseWithCovarianceStamped  # 初始化位姿消息
from llm_vlm_brain_interfaces.srv import Chat         # 自定义服务：LLM 对话请求/响应
from llm_vlm_brain_interfaces.srv import VisionDescribe  # 自定义服务：VLM 视觉描述请求/响应
from tts_asr_interfaces.srv import Tts                # TTS 服务：文字转语音
from geometry_msgs.msg import PoseStamped
from nav_msgs.msg import Odometry
from tf2_ros import TransformListener, Buffer
from tf_transformations import euler_from_quaternion, quaternion_from_euler
from nav2_simple_commander.robot_navigator import BasicNavigator

class LLMChatNode(BasicNavigator):       # 继承 ROS2 Node，定义 LLM 对话节点

    _TAG_RE = re.compile(r'<(move|vlm|sensor|nav|weather|chat)>(.*?)</\1>', re.DOTALL)

    def __init__(self):
        super().__init__('llm_chat_node')   # 调用父类构造，节点名称为 llm_chat_node

        # ---- 参数 ----
        self.declare_parameter('llm_url', 'http://localhost:8080')   # 声明参数：LLM 服务地址（llama.cpp server）
        self.declare_parameter('model_name', 'qwen3')                # 声明参数：模型名称
        self.declare_parameter('temperature', 0.7)                   # 声明参数：温度（越高越随机）
        self.declare_parameter('max_tokens', 2560)                    # 声明参数：最大生成长度
        self.llm_url = self.get_parameter('llm_url').value           # 读取 llm_url 参数值
        self.model_name = self.get_parameter('model_name').value     # 读取 model_name 参数值
        self.temperature = self.get_parameter('temperature').value   # 读取 temperature 参数值
        self.max_tokens = self.get_parameter('max_tokens').value     # 读取 max_tokens 参数值
        # 拼接完整的 OpenAI 兼容 Chat API 地址
        self.chat_api = f"{self.llm_url.rstrip('/')}/v1/chat/completions"

        # ---- 运动参数 ----
        self.MAX_LINEAR = 0.2     # 安全限速：最大线速度 0.2 m/s（防止小车跑太快）
        self.MAX_ANGULAR = 3.0    # 安全限速：最大角速度 3.0 rad/s（防止旋转太猛）
        self.linear_speed = 0.2  # 实际使用的线速度 m/s（前进/后退时用）
        self.angular_speed = 2.0  # 实际使用的角速度 rad/s（左转/右转时用）

        # ---- 定时器句柄(用于自动停止) ----
        self._stop_timer = None   # 存储当前运动的停止定时器，新命令来时要取消旧的

        # ---- ASR 防抖：短时间内重复识别不重复处理 ----
        self._last_asr_time = 0   # 上次 ASR 处理时间戳
        self._asr_debounce = 3.0  # ASR 防抖间隔(秒)，在此时间内的新 ASR 结果会被忽略

        self.buffer_ = Buffer()
        self.listener_ = TransformListener(self.buffer_, self)

        # ---- 传感器数据缓存（后台订阅话题持续更新） ----
        self.battery_voltage = 0.0     # 缓存电池电压 (V)，从 /robot_state 话题获取
        self.temperature = 0.0         # 缓存温度值(℃)，从 /sensor_temp_humidity 获取
        self.humidity = 0.0            # 缓存湿度值(%)，从 /sensor_temp_humidity 获取
        self._latest_odom = None       # 缓存最新里程计消息，用于初始化位姿

        # ---- 天气查询参数 ----
        self.declare_parameter('weather_city', '芜湖')       # 默认城市
        self.weather_city = self.get_parameter('weather_city').value

        # ---- 导航相关 ----
        self._named_locations = {}     # 命名地点字典 {名称: (x, y)}，如 {'家': (2.0, 8.0), '卧室': (2.0, 8.0)}
        self._locations_file = os.path.expanduser('/home/sunrise/gm_car/colcon_ws/src/llm_vlm_brain_node/location/nav_locations.json')  # 地点持久化文件路径
        self._nav_busy = False         # 导航是否正在执行中（防止重复导航）
        self._nav_lock = threading.Lock()  # 导航状态锁（保证跨线程安全）
        self._initialpose_pub = self.create_publisher(
            PoseWithCovarianceStamped, '/initialpose', 10)   # 初始位姿发布者
        self._load_locations()          # 从文件加载已保存的地点

        # ---- 订阅传感器话题 ----
        self.create_subscription(
            RobotStatus, '/robot_state', self.robot_state_callback, 10
        )  # 订阅小车状态话题，获取电池电压/位姿等信息
        self.create_subscription(
            Float32MultiArray, '/sensor_temp_humidity', self.sensor_temp_humidity_callback, 10
        )      # 订阅温湿度传感器话题，data[1]=温度, data[2]=湿度
        self.create_subscription(
            Odometry, '/odom', self._odom_callback, 10
        )      # 订阅里程计话题，用于初始化位姿

        # ---- 订阅 ASR 结果 ----
        # 订阅 /asr_result 话题，收到语音识别结果后自动调用 LLM
        self.create_subscription(String, '/asr_result', self.asr_result_callback, 10)

        # ==================== System Prompt（发送给 LLM 的系统提示词）====================
        self.system_prompt = (
            "你是一辆智能小车的语音助手，名叫地瓜。回答要简洁口语化，像朋友聊天。\n\n"
            "【重要规则】\n"
            "- 根据用户意图在回答末尾添加对应的功能标签\n"
            "- 可以添加多个标签来组合多个任务，系统会按顺序依次执行每个任务\n"
            "- 标签之间的顺序代表执行顺序：先写的先执行\n"
            "- 闲聊、打招呼、自我介绍等不加任何标签\n"
            "- 多个任务时，每个任务的标签都要写完整，不要省略\n\n"

            "===== 一、移动控制 <move> =====\n"
            "当用户要让小车移动时使用。\n"
            "<move> 里只能填：forward, backward, left, right, stop\n"
            "格式：<move>action param</move>\n"
            "  <move>forward 1</move>       前进1米\n"
            "  <move>backward 0.5</move>     后退0.5米\n"
            "  <move>left</move>             左转90度\n"
            "  <move>right 360</move>       右转360度(一圈)\n"
            "  <move>stop</move>             立即停车\n\n"

            "===== 二、视觉问答 <vlm> =====\n"
            "当用户想了解摄像头看到的画面时使用。系统会自动调用视觉模型分析摄像头画面。\n"
            "格式：<vlm>你要问的问题</vlm>\n"
            "  <vlm>你看到了什么</vlm>          描述整个画面\n"
            "  <vlm>前面有红色物体吗</vlm>      检测特定目标\n"
            "  <vlm>红色物体在哪里</vlm>        定位目标位置\n"
            "  <vlm>距离最近的障碍物是什么</vlm> 障碍物检测\n"

            "===== 三、传感器查询 <sensor> =====\n"
            '当用户想查询小车状态或环境数据时使用。系统会读取实时传感器数据,你自己无需回答具体数值,回答类似与「正在查询」之类的就行。\n'
            "格式：<sensor>查询类型</sensor>\n"
            "  <sensor>voltage</sensor>            查询电池电压\n"
            "  <sensor>temperature</sensor>        查询当前温度\n"
            "  <sensor>humidity</sensor>           查询当前湿度\n"
            "  <sensor>all</sensor>                查询全部(电压+温湿度)\n\n"

            "===== 四、导航控制 <nav> =====\n"
            "当用户要让小车导航到指定位置、初始化位置、或管理命名地点时使用。\n"
            "格式：<nav>子命令 [参数]</nav>\n\n"

            "子命令：\n"
            "  goto x y          → 导航到坐标(x,y)，如 <nav>goto 3.0 4.0</nav>\n"
            "  goto 地点名        → 导航到已保存的命名地点，如 <nav>goto 卧室</nav>\n"
            "  init              → 将当前位置设为初始位姿，如 <nav>init</nav>\n"
            "  save 名称 x y      → 保存/更新命名地点坐标，如 <nav>save 卧室 2.0 8.0</nav>\n"
            "  waypoints x y;x y;... → 多点导航航（分号分隔每个点），如 <nav>waypoints 3 4;5 6;2 8</nav>\n\n"

            "已保存的地点（动态更新，用户可能随时添加/修改）：\n"
            "  {{LOCATIONS}}\n\n"

            "===== 五、天气查询 <weather> =====\n"
            "当用户想查询天气时使用。系统会自动调用天气API获取实时数据。\n"
            "格式：<weather>城市名</weather>\n"
            "  <weather>北京</weather>         查询北京天气\n"
            "  <weather>上海</weather>         查询上海天气\n"
            "  <weather>默认</weather>         查询当前所在城市天气\n\n"

            "===== 六、聊天回复 <chat> =====\n"
            "当需要给用户一段明确的聊天回复并通过语音播报时使用。\n"
            "格式：<chat>回复内容</chat>\n"
            "  <chat>你好呀！很高兴见到你！</chat>\n"
            "  <chat>今天天气不错哦，适合出门走走。</chat>\n"
            "注意：如果回复中已经包含了其他功能标签(<move>/<vlm>/<sensor>/<nav>/<weather>)，则不需要再加<chat>标签。\n"
            "只有当回复纯粹是对话交流、不需要触发任何功能时才使用<chat>标签。\n\n"

            "===== 七、多任务组合（重要！）=====\n"
            "当用户的请求包含多个步骤时，按执行顺序写出所有标签。标签顺序就是执行顺序。\n"
            "典型场景：先导航到某地 → 再做其他操作（看/测/说）\n\n"
            "多任务示例：\n"
            "  用户：去卧室描述环境并检测温湿度\n"
            "    → 回复：好的，我先去卧室，然后描述环境，再检测温湿度。<nav>goto 卧室</nav><vlm>描述一下周围的环境</vlm><sensor>all</sensor>\n\n"
            "  用户：去厨房看看有什么\n"
            "    → 回复：好的，我去厨房看看。<nav>goto 厨房</nav><vlm>你看到了什么</vlm>\n\n"
            "  用户：去客厅查一下温湿度\n"
            "    → 回复：好的，去客厅查温湿度。<nav>goto 客厅</nav><sensor>all</sensor>\n\n"
            "  用户：前进一米然后看看前面有什么\n"
            "    → 回复：好的，前进一米后观察前方。<move>forward 1</move><vlm>你看到了什么</vlm>\n\n"
            "  用户：去卧室，描述一下环境，然后回来\n"
            "    → 回复：好的，去卧室描述环境后返回。<nav>goto 卧室</nav><vlm>描述一下周围的环境</vlm><nav>goto 家</nav>\n\n"
            "多任务规则：\n"
            "- 标签必须按执行顺序排列，先发生的写前面\n"
            "- 导航通常放在最前面（因为要先到达才能做后续操作）\n"
            "- 每个标签都要完整，不能省略\n"
            "- 不要在一个标签里塞多个操作，每个操作一个标签\n\n"

            "示例：\n\n"
            "【移动控制】\n"
            "用户：前进一米        → 回复：好的，前进1米。<move>forward 1</move>\n"
            "用户：后退两米        → 回复：好的，后退2米。<move>backward 2</move>\n"
            "用户：左转            → 回复：好的，左转90度。<move>left</move>\n"
            "用户：右转一圈        → 回复：好的，右转360度。<move>right 360</move>\n"
            "用户：停下/停车/刹车  → 回复：好的，已停车。<move>stop</move>\n"
            "用户：往前走          → 回复：好的，往前走。<move>forward 0.5</move>\n\n"

            "【视觉问答】\n"
            "用户：你看到了什么      → 回复：让我看看。<vlm>你看到了什么</vlm>\n"
            "用户：前面有什么       → 回复：好的，看看前面。<vlm>你看到了什么</vlm>\n"
            "用户：有红色的东西吗   → 回复：让我检查一下。<vlm>有红色物体吗</vlm>\n"
            "用户：看看周围环境     → 回复：正在观察环境。<vlm>描述一下周围的环境</vlm>\n\n"

            "【传感器查询】\n"
            "用户：电压多少/还有多少电 → 回复：<sensor>voltage</sensor>\n"
            "用户：现在几度/温度怎么样   → 回复：<sensor>temperature</sensor>\n"
            "用户：湿度呢              → 回复：<sensor>humidity</sensor>\n"
            "用户：查一下所有传感器     → 回复：<sensor>all</sensor>\n"
            "用户：电量还够吗           → 回复：<sensor>voltage</sensor>\n\n"

            "【导航控制】\n"
            "用户：去3 4           → 回复：好的，导航到(3,4)。<nav>goto 3 4</nav>\n"
            "用户：去卧室          → 回复：好的，去卧室。<nav>goto 卧室</nav>\n"
            "用户：回家            → 回复：好的，回家。<nav>goto 家</nav>\n"
            "用户：初始化          → 回复：好的，已将当前位置设为初始位姿。<nav>init</nav>\n"
            "用户：把卧室定为2 8   → 回复：好的，卧室位置已记录为(2,8)。<nav>save 卧室 2 8</nav>\n"
            "用户：厨房更新为4 7   → 回复：好的，厨房位置已更新为(4,7)。<nav>save 厨房 4 7</nav>\n"
            "用户：先去厨房再去卧室 → 回复：好的，先去厨房再去的卧室。<nav>waypoints 厨房;卧室</nav>\n"
            "用户：巡逻这三个点    → 回复：好的，开始多点巡逻。<nav>waypoints 3 4;5 6;2 8</nav>\n\n"

            "【天气查询】\n"
            "用户：今天天气怎么样   → 回复：让我查查天气。<weather>默认</weather>\n"
            "用户：北京天气如何     → 回复：好的，查一下北京天气。<weather>北京</weather>\n"
            "用户：明天会下雨吗     → 回复：帮你看看天气。<weather>默认</weather>\n\n"

            "【聊天回复】\n"
            "用户：你好            → 回复：<chat>你好呀！有什么可以帮你的？</chat>\n"
            "用户：你是谁          → 回复：<chat>我是地瓜，你的智能小车助手！很高兴认识你。</chat>\n"
            "用户：谢谢            → 回复：<chat>不客气！随时为你服务~</chat>\n"
            "用户：你今天心情好吗   → 回复：<chat>当然好呀！能陪你聊天我超开心的！</chat>\n"
            "用户：讲个笑话        → 回复：<chat>为什么程序员总是分不清万圣节和圣诞节？因为 Oct 31 = Dec 25！哈哈</chat>\n\n"

            "语音识别可能将数字转为汉字（如'三四'='3 4'、'二八'='2 8'、'两米'='2米'），请正确理解并转为阿拉伯数字。\n"
        )

        # ---- 服务客户端 ----
        self.tts_client = self.create_client(Tts, 'tts')   # TTS 语音合成客户端
        # VLM 视觉描述客户端：调用 /vlm_describe 服务让视觉模型分析摄像头画面
        self.vlm_client = self.create_client(VisionDescribe, 'vlm_describe')

        # ---- Chat.srv 服务 ----
        self.create_service(Chat, 'llm_chat', self.chat_callback)

        # ---- /cmd_vel 发布者 ----
        # 发布速度指令到 /cmd_vel，底层驱动订阅此话题控制电机
        self.cmd_vel_pub = self.create_publisher(Twist, '/cmd_vel', 10)

        # 打印启动日志
        self.get_logger().info(
            f'LLM对话节点已启动 | 线速度≤{self.MAX_LINEAR}m/s | 角速度≤{self.MAX_ANGULAR}rad/s'
        )
        self.get_logger().info(f'支持标签: <move>运动 | <vlm>视觉 | <sensor>传感器 | <nav>导航 | <weather>天气 | <chat>聊天')
        self.get_logger().info(f'默认城市: {self.weather_city}')
        self.get_logger().info(f'已加载地点: {self._named_locations or "无"}')

        # ---- 启动时验证与下位机的ROS2通信连通性（延迟3秒等待DDS发现完毕） ----
        self._conn_timer = self.create_timer(3.0, self._check_connectivity)  # 回调内cancel实现oneshot


    def _check_connectivity(self):
        """启动时一次性验证与下位机的ROS2通信是否通畅（延迟3秒调用）"""
        self._conn_timer.cancel()  # oneshot: 只执行一次

        self.get_logger().info('====== 正在验证与下位机的通信连接 ======')

        # 辅助：使用 ROS2 API 检查话题是否有发布者（替代 subprocess 调 ros2 topic info）
        def check_topic(topic_name, device_desc):
            try:
                publishers = self.get_publishers_info_by_topic(topic_name)
                if publishers:
                    self.get_logger().info(f'[OK] {topic_name} → {device_desc}在线')
                else:
                    self.get_logger().warning(f'[FAIL] {topic_name} → {device_desc}未连接')
            except Exception as e:
                self.get_logger().warning(f'[ERROR] 检查 {topic_name}: {e}')

        check_topic('/asr_result',          '麦克风')
        check_topic('/sensor_temp_humidity', '机械臂')
        self.get_logger().info('====== 连通性验证完成 ======')

    @staticmethod
    def _normalize_chinese_numbers(text: str) -> str:
        """将 ASR 输出中的中文数字转为阿拉伯数字（支持组合数字如"二十三"）

        示例：
            '去三四'         → '去3 4'
            '前进两米'       → '前进2米'
            '卧室定为二八'   → '卧室定为2 8'
            '右转九十度'     → '右转90度'
            '去二十三'       → '去23'
            '去卧室'         → '去卧室'（非数字不动）
        """
        CN = {'零':0,'一':1,'二':2,'两':2,'三':3,'四':4,'五':5,'六':6,'七':7,'八':8,'九':9}
        UNIT = {'十':10,'百':100,'千':1000,'万':10000}

        def parse_cn_number(s):
            """解析连续中文数字字符串为整数，失败返回None"""
            if not s:
                return None
            if s[0] == '十':  # "十"开头如"十五"=15
                s = '一' + s
            result = 0
            current = 0
            for ch in s:
                if ch in CN:
                    current = CN[ch]
                elif ch in UNIT:
                    if current == 0:
                        current = 1
                    result += current * UNIT[ch]
                    current = 0
                else:
                    return None
            result += current
            return result if result > 0 else None

        # 找出连续中文数字片段并替换
        all_chars = set(CN.keys()) | set(UNIT.keys())
        pattern = '[' + ''.join(re.escape(c) for c in all_chars) + ']+'

        def replace_match(m):
            original = m.group(0)
            num = parse_cn_number(original)
            if num is not None:
                return str(num)
            return original

        return re.sub(pattern, replace_match, text)

    def asr_result_callback(self, msg: String):
        """ASR 话题回调：收到语音识别结果后自动处理（带防抖，异步执行 LLM 不阻塞 spin）"""
        # 防抖：短时间内重复的 ASR 结果不重复处理
        now = time.time()
        if now - self._last_asr_time < self._asr_debounce:
            self.get_logger().info(f'ASR防抖: 距上次{now - self._last_asr_time:.1f}s < {self._asr_debounce}s，跳过')
            return
        self._last_asr_time = now

        text = msg.data                    # 从消息中提取识别到的文本
        if not text or not text.strip():   # 如果文本为空或纯空白，直接忽略
            return
        text = self._normalize_chinese_numbers(text)
        self.get_logger().info(f'ASR识别: "{text}"')   # 打印收到的 ASR 文本

        # 异步处理：在独立线程中调用 LLM，避免阻塞 ROS2 spin 主循环（LLM 可能耗时 10~120 秒）
        threading.Thread(target=self._handle_asr_llm, args=(text,), daemon=True).start()

    def _execute_cmds(self, reply, task_list):
        """根据任务列表串行执行所有任务（前一个完成后才执行下一个）。

        Args:
            reply: LLM 纯文本回复（无标签）
            task_list: 有序任务列表 [{'type':str, 'data':...}, ...]
        """
        # 先播报 LLM 的文字回复（如果有）
        if reply and reply != '（无内容）':
            self._call_tts_sync(reply)

        if not task_list:
            # 无任务但有回复文本时，上面已经播报了
            self.get_logger().info(f'LLM回复(无任务): "{reply}"')
            return

        self.get_logger().info(f'共 {len(task_list)} 个任务，开始串行执行')
        for i, task in enumerate(task_list):
            self.get_logger().info(f'--- 执行任务 [{i+1}/{len(task_list)}]: <{task["type"]}> ---')
            try:
                self._execute_single_task(task)
            except Exception as e:
                self.get_logger().error(f'任务[{i+1}]<{task["type"]}> 执行异常: {e}')
                self._call_tts_sync(f'抱歉，第{i+1}个任务出错了')
            # 任务间短暂间隔，让 TTS 有时间播报
            if i < len(task_list) - 1:
                time.sleep(0.5)

        self.get_logger().info(f'全部 {len(task_list)} 个任务执行完毕')

    def _execute_single_task(self, task):
        """同步执行单个任务（阻塞直到完成）

        Args:
            task: {'type': str, 'data': ...}
        """
        task_type = task['type']
        data = task['data']

        if task_type == 'nav':
            self._execute_nav_sync(data)
        elif task_type == 'vlm':
            self._call_vlm_sync(data)
        elif task_type == 'sensor':
            self._execute_sensor_query(data)
        elif task_type == 'move':
            self._execute_move(data)
        elif task_type == 'weather':
            self._execute_weather_sync(data)
        elif task_type == 'chat':
            self._call_tts_sync(data)
        else:
            self.get_logger().warning(f'未知任务类型: {task_type}')

    def _execute_nav_sync(self, cmd):
        """同步执行导航命令（阻塞直到导航完成或失败）"""
        sub = cmd.get('sub', '')
        try:
            if sub == 'goto':
                self._nav_goto(cmd)           # nav_to_pose 本身就是阻塞式的
            elif sub == 'init':
                self._nav_init()              # init 是同步的
            elif sub == 'save':
                self._nav_save_location(cmd)  # save 是同步的
            elif sub == 'waypoints':
                self._nav_waypoints(cmd)      # waypoints 内部串行调用 nav_to_pose
            else:
                self.get_logger().warning(f'未知导航子命令: {sub}')
                self._call_tts_sync('抱歉，未知的导航命令')
        except Exception as e:
            self.get_logger().error(f'导航执行异常: {e}')
            self._call_tts_sync(f'抱歉，导航出错：{e}')

    def _call_vlm_sync(self, query):
        """同步调用 VLM 服务（阻塞等待结果）"""
        if not self.vlm_client.service_is_ready():
            self.get_logger().warning('VLM 服务(/vlm_describe)未就绪，跳过视觉查询')
            self._call_tts_sync('抱歉，视觉模块还没准备好')
            return

        req = VisionDescribe.Request()
        req.query = query
        self.get_logger().info(f'[同步]调用VLM服务 -> query="{query}"')

        future = self.vlm_client.call_async(req)
        # 阻塞等待 VLM 完成（轮询方式，带30秒超时）
        _deadline = time.time() + 30
        while not future.done():
            if time.time() > _deadline:
                self.get_logger().error('VLM 调用超时(30s)')
                self._call_tts_sync('抱歉，视觉服务超时了')
                return
            time.sleep(0.2)

        # 处理结果
        try:
            result = future.result()
            desc = result.description
            if result.result and desc:
                self.get_logger().info(f'VLM返回: "{desc}"')
                self._call_tts_sync(desc)
            else:
                self.get_logger().warning('VLM 描述失败或返回空')
                self._call_tts_sync('抱歉，视觉分析没有成功')
        except Exception as e:
            self.get_logger().error(f'VLM 调用异常: {e}')
            self._call_tts_sync('抱歉，视觉服务出错了')

    def _execute_weather_sync(self, city):
        """同步查询天气（在当前线程中直接执行 HTTP 请求）"""
        try:
            url = f"https://wttr.in/{city}?format=j1&lang=zh"
            resp = requests.get(url, timeout=10)
            resp.raise_for_status()
            data = resp.json()

            current = data['current_condition'][0]
            temp = current['temp_C']
            feels_like = current['FeelsLikeC']
            humidity = current['humidity']
            if 'lang_zh' in current and current['lang_zh']:
                desc = current['lang_zh'][0]['value']
            elif 'weatherDesc' in current and current['weatherDesc']:
                desc = current['weatherDesc'][0]['value']
            else:
                desc = '未知'
            wind_speed = current['windspeedKmph']

            reply = (
                f"{city}现在{desc}，气温{temp}度，"
                f"体感{feels_like}度，湿度{humidity}%，"
                f"风速{wind_speed}公里每小时"
            )
            self.get_logger().info(f'天气查询: {reply}')
            self._call_tts_sync(reply)

        except requests.exceptions.Timeout:
            self._call_tts_sync('抱歉，天气查询超时了')
        except requests.exceptions.ConnectionError:
            self._call_tts_sync('抱歉，无法连接天气服务')
        except Exception as e:
            self.get_logger().error(f'天气查询出错: {e}')
            self._call_tts_sync('抱歉，查天气出了点问题')

    def _call_tts_sync(self, text):
        """同步调用 TTS 并等待播报完成"""
        if not text or not text.strip():
            return
        if not self.tts_client.service_is_ready():
            self.get_logger().warning('TTS 未就绪，跳过')
            return
        req = Tts.Request()
        req.text = text
        future = self.tts_client.call_async(req)
        # 等待 TTS 完成（带60秒超时）
        _deadline = time.time() + 60
        while not future.done():
            if time.time() > _deadline:
                self.get_logger().warning('TTS 播报超时(60s)')
                return
            time.sleep(0.1)
        try:
            result = future.result()
            if result.result:
                self.get_logger().info(f'TTS 播报成功: "{text[:30]}..."')
            else:
                self.get_logger().warning(f'TTS 播报失败: "{text[:30]}"')
        except Exception as e:
            self.get_logger().error(f'TTS 异常: {e}')

    def _handle_asr_llm(self, text: str):
        """在后台线程中完成 ASR -> LLM -> 串行执行任务队列 的完整流程"""
        reply, task_list = self._call_llm(text)
        self._execute_cmds(reply, task_list)

    def chat_callback(self, request, response):
        """/llm_chat 服务回调：处理外部程序发来的对话请求（如 ros2 service call）

        在独立线程中执行 LLM+任务链，避免阻塞 ROS2 spin 主循环。
        """
        reply, task_list = self._call_llm(request.message)
        # 将耗时任务放到后台线程执行，service 立即返回回复文本
        threading.Thread(target=self._execute_cmds, args=(reply, task_list), daemon=True).start()
        response.response = reply
        response.result = bool(reply and not reply.startswith('抱歉'))
        return response

    # ======================== LLM 调用与标签解析 ========================

    def _parse_tag(self, tag_type: str, tag_content: str):
        """解析单个标签内容，返回解析后的数据。解析失败返回 None。

        Args:
            tag_type: 标签类型 (move/vlm/sensor/nav/weather/chat)
            tag_content: 标签内的原始文本

        Returns:
            解析后的数据（格式因类型而异），None 表示无效标签
        """
        if tag_type == 'move':
            parts = tag_content.split()
            action = parts[0].lower()
            param = float(parts[1]) if len(parts) > 1 else None
            VALID_MOVE_ACTIONS = {'forward', 'backward', 'left', 'right', 'stop'}
            if action in VALID_MOVE_ACTIONS:
                return {'action': action, 'param': param}
            self.get_logger().warning(f'忽略非法移动动作: {action}')
            return None

        elif tag_type == 'vlm':
            if tag_content:
                return tag_content
            return None

        elif tag_type == 'sensor':
            sensor_type = tag_content.lower()
            VALID_SENSOR_TYPES = {'voltage', 'temperature', 'humidity', 'all'}
            if sensor_type in VALID_SENSOR_TYPES:
                return sensor_type
            self.get_logger().warning(f'忽略非法传感器类型: {sensor_type}')
            return None

        elif tag_type == 'nav':
            return self._parse_nav_command(tag_content)

        elif tag_type == 'weather':
            city = tag_content.strip()
            if city.lower() in ('默认', 'default', ''):
                city = self.weather_city
            return city

        elif tag_type == 'chat':
            if tag_content:
                return tag_content
            return None

        else:
            self.get_logger().warning(f'未知标签类型: {tag_type}')
            return None

    def _call_llm(self, user_message):
        """
        调用 LLM API（OpenAI 兼容格式），从输出中解析所有功能标签。
        支持多任务：LLM 可返回多个标签，按顺序组成任务队列依次执行。

        返回: (纯文本回复, 任务列表[{'type':str, 'data':...}, ...])
              任务列表为空时表示无命令需执行
        """
        # 构造 OpenAI 格式的对话 messages：system 提示词 + 用户输入
        # 动态替换地点占位符，让 LLM 感知最新保存的地点
        dynamic_prompt = self.system_prompt.replace('{{LOCATIONS}}', self._format_locations_for_prompt())
        messages = [
            {"role": "system", "content": dynamic_prompt},  # 系统角色：包含所有规则和示例
            {"role": "user", "content": user_message},           # 用户角色：用户的原始输入
        ]
        try:
            # 发送 HTTP POST 请求到 llama.cpp 的 /v1/chat/completions 接口
            resp = requests.post(
                self.chat_api,
                json={
                    "model": self.model_name,
                    "messages": messages,
                    "stream": False,
                    "temperature": self.temperature,
                    "max_tokens": self.max_tokens,
                },
                timeout=120,
            )
            resp.raise_for_status()
            # 从 JSON 响应中提取 LLM 生成的文本内容
            msg = resp.json()['choices'][0]['message']
            content = msg.get('content', '').strip()
            reasoning = msg.get('reasoning_content', '').strip()
            # Qwen3 思考模式：content 为空时，用 reasoning_content 作为回复
            if not content and reasoning:
                content = reasoning
            if not content:
                return ('（无内容）', [])

            # ===== 解析所有标签（支持多任务，按出现顺序排列） =====
            reply_text = content              # 默认回复就是 LLM 原始输出
            task_list = []                    # 有序任务列表 [{'type': str, 'data': ...}, ...]

            # 用 finditer 匹配所有标签，保持顺序
            for match in self._TAG_RE.finditer(content):
                tag_type = match.group(1)
                tag_content = match.group(2).strip()
                parsed = self._parse_tag(tag_type, tag_content)
                if parsed is not None:
                    task_list.append({'type': tag_type, 'data': parsed})
                    self.get_logger().info(f'解析到任务 [{tag_type}]: {parsed}')

            # 删除所有标签，得到纯净的 TTS 播报文本
            reply_text = self._TAG_RE.sub('', content).strip()

            if not reply_text:                 # 如果删完标签后文本为空（如仅返回 <chat>xxx</chat>）
                reply_text = ''                # 留空，由 _execute_cmds 根据 cmds 决定是否播报

            return (reply_text, task_list)

        except requests.exceptions.Timeout:
            return ("抱歉，思考太久了，请再试一次。", [])
        except requests.exceptions.ConnectionError:
            self.get_logger().error(f'无法连接 LLM: {self.llm_url}')
            return ("抱歉，无法连接语言模型服务。", [])
        except Exception as e:
            self.get_logger().error(f'LLM 出错: {e}')
            return (f"抱歉，出错: {e}", [])

    # ======================== 运动执行 ========================

    def _execute_move(self, cmd):
        """
        解析运动命令字典，计算速度和时间，发布 /cmd_vel，设置自动停止定时器。
        cmd 格式: {'action': 'forward'|'backward'|'left'|'right'|'stop', 'param': 浮点数 或 None}
        """
        action = cmd['action']      # 提取动作类型
        param = cmd['param']        # 提取参数（距离米数 或 角度度数，stop 时为 None）

        # 取消之前的自动停止定时器（新命令必须打断正在执行的运动，防止叠加）
        if self._stop_timer is not None:
            self._stop_timer.cancel()  # 取消旧定时器
            self._stop_timer = None    # 清空引用

        twist = Twist()                 # 创建速度消息对象（默认全零=停止）
        duration = None                 # 自动停止的倒计时秒数（None 表示不自动停）

        # ===== 根据 action 类型分别计算速度和持续时间 =====
        if action == 'forward':
            dist = param if param else 0.5       # 目标距离，没指定则默认 0.5 米
            twist.linear.x = min(self.linear_speed, self.MAX_LINEAR)
            duration = dist / twist.linear.x if twist.linear.x > 0 else None

        elif action == 'backward':
            dist = param if param else 0.5
            twist.linear.x = -min(self.linear_speed, self.MAX_LINEAR)
            duration = dist / abs(twist.linear.x) if twist.linear.x != 0 else None

        elif action == 'left':
            angle_deg = 90 if not param else param
            twist.angular.z = min(self.angular_speed, self.MAX_ANGULAR)
            duration = (angle_deg / 360) * (2 * math.pi / twist.angular.z) if twist.angular.z > 0 else None

        elif action == 'right':
            angle_deg = 90 if not param else param
            twist.angular.z = -min(self.angular_speed, self.MAX_ANGULAR)
            duration = (angle_deg / 360) * (2 * math.pi / abs(twist.angular.z)) if twist.angular.z != 0 else None

        elif action == 'stop':
            pass  # twist 保持全零状态，即停止运动

        else:
            self.get_logger().warning(f'未知动作: {action}')
            return

        # 发布速度指令到底层驱动（电机开始运转）
        self.cmd_vel_pub.publish(twist)

        # 构造人类可读的日志信息
        info_parts = []
        if twist.linear.x != 0:
            info_parts.append(f'线速={twist.linear.x:.2f}m/s')
        if twist.angular.z != 0:
            info_parts.append(f'角速={twist.angular.z:.2f}rad/s')
        if duration:
            info_parts.append(f'{duration:.1f}秒后自停')
        self.get_logger().info(
            f'/cmd_vel -> {action}' + (f' param={param}' if param else '') +
            f' | {" ".join(info_parts)}'
        )
        # 设置自动停止定时器
        if duration and duration > 0:
            self._stop_timer = self.create_timer(duration, self._auto_stop)

    def _auto_stop(self):
        """自动停止回调：定时器到期后被调用，发布零速度让小车停下，然后销毁定时器"""
        self.cmd_vel_pub.publish(Twist())
        self.get_logger().info('/cmd_vel -> 自动停止')
        if self._stop_timer is not None:
            self._stop_timer.cancel()
            self._stop_timer = None

    # ======================== VLM 视觉服务调用 ========================

    def _call_vlm_service(self, query):
        """
        异步调用 /vlm_describe 服务，将摄像头画面发给视觉语言模型进行分析。
        query: 发给VLM的提示词（如"你看到了什么"、"有红色物体吗"）
        """
        if not self.vlm_client.service_is_ready():
            self.get_logger().warning('VLM 服务(/vlm_describe)未就绪，跳过视觉查询')
            self._call_tts('抱歉，视觉模块还没准备好')
            return
        req = VisionDescribe.Request()   # 构造 VLM 服务请求对象
        req.query = query               # 填入要问的问题/提示词
        self.get_logger().info(f'调用VLM服务 -> query="{query}"')
        # 异步调用，不阻塞主线程（VLM 推理可能需要几秒到十几秒）
        future = self.vlm_client.call_async(req)
        future.add_done_callback(self._vlm_done)   # 直接绑定回调方法

    def _vlm_done(self, future):
        """
        VLM 异步调用完成后的回调：获取视觉描述结果并通过 TTS 播报
    
        Args:
        future (rclpy.task.Future): ROS2 异步服务调用的 Future 对象，包含 VLM 服务的响应结果
    
        Raises:
        Exception: VLM 服务调用或结果解析过程中发生的任何异常，会被捕获并记录错误日志
        """ 
        try:
            result = future.result()     # 获取 VisionDescribe.srv 的响应
            desc = result.description     # VLM 对图像的文字描述
            if result.result and desc:
                self.get_logger().info(f'VLM返回: "{desc}"')
                self._call_tts(desc)     # 将 VLM 描述转为语音播报给用户
            else:
                self.get_logger().warning('VLM 描述失败或返回空')
                self._call_tts('抱歉，视觉分析没有成功')
        except Exception as e:
            self.get_logger().error(f'VLM 调用异常: {e}')
            self._call_tts('抱歉，视觉服务出错了')

    # ======================== 传感器查询 ========================

    def _execute_sensor_query(self, sensor_type):
        """
        根据查询类型读取缓存的传感器数据，拼接自然语言描述并通过 TTS 播报。
        sensor_type: 'voltage' | 'temperature' | 'humidity' | 'all'
        """
        # 根据查询类型拼播报文本
        parts = []  # 存储各传感器的描述片段

        if sensor_type in ('voltage', 'all'):
            parts.append(f"当前电压{self.battery_voltage:.1f}伏")
        if sensor_type in ('temperature', 'all'):
            parts.append(f"当前温度{self.temperature:.1f}度")
        if sensor_type in ('humidity', 'all'):
            parts.append(f"当前湿度{self.humidity:.1f}%")

        if parts:
            reply_text = "，".join(parts)
            self.get_logger().info(f'传感器查询({sensor_type}): {reply_text}')
            self._call_tts_sync(reply_text)
        else:
            self.get_logger().warning(f'未知传感器类型: {sensor_type}')
            self._call_tts_sync('抱歉，不知道要查什么传感器')

    # ======================== 天气查询 <weather> ========================

    def _execute_weather_query(self, city):
        """
        查询指定城市的实时天气，通过 TTS 播报。
        使用 wttr.in API（免费、无需密钥），在子线程中执行避免阻塞 ROS2 spin。
        """
        def _fetch():
            try:
                url = f"https://wttr.in/{city}?format=j1&lang=zh"
                resp = requests.get(url, timeout=10)
                resp.raise_for_status()
                data = resp.json()

                current = data['current_condition'][0]
                temp = current['temp_C']
                feels_like = current['FeelsLikeC']
                humidity = current['humidity']
                if 'lang_zh' in current and current['lang_zh']:
                    desc = current['lang_zh'][0]['value']
                elif 'weatherDesc' in current and current['weatherDesc']:
                    desc = current['weatherDesc'][0]['value']
                else:
                    desc = '未知'
                wind_speed = current['windspeedKmph']

                reply = (
                    f"{city}现在{desc}，气温{temp}度，"
                    f"体感{feels_like}度，湿度{humidity}%，"
                    f"风速{wind_speed}公里每小时"
                )
                self.get_logger().info(f'天气查询: {reply}')
                self._call_tts(reply)

            except requests.exceptions.Timeout:
                self._call_tts('抱歉，天气查询超时了')
            except requests.exceptions.ConnectionError:
                self._call_tts('抱歉，无法连接天气服务')
            except Exception as e:
                self.get_logger().error(f'天气查询出错: {e}')
                self._call_tts('抱歉，查天气出了点问题')

        threading.Thread(target=_fetch, daemon=True).start()

    def robot_state_callback(self, msg):
        """
        /robot_state 话题回调：接收小车状态数据(RobotStatus)，更新缓存。
        """
        try:
            self.battery_voltage = float(msg.battery_voltage)
            if msg.is_valid:
                self._robot_pose_x = float(msg.x_position)
                self._robot_pose_y = float(msg.y_position)
                self._robot_angle = float(msg.angle)
        except (ValueError, AttributeError) as e:
            self.get_logger().warning(f'解析 robot_state 消息失败: {e}')

    def sensor_temp_humidity_callback(self, msg: Float32MultiArray):
        """
        /sensor_temp_humidity 话题回调：接收温湿度数据（Float32MultiArray）。
        数据布局: data[0]=保留, data[1]=温度(℃), data[2]=湿度(%)
        """
        if len(msg.data) >= 3:
            self.temperature = float(msg.data[1])
            self.humidity = float(msg.data[2])
        else:
            self.get_logger().warning(
                f'sensor_temp_humidity 数据长度不足: 期望>=3, 实际={len(msg.data)}'
            )

    def _odom_callback(self, msg: Odometry):
        """里程计回调：缓存最新的 odom 消息"""
        self._latest_odom = msg

    # ======================== 导航控制 <nav> ========================

    def _parse_nav_command(self, raw: str):
        """
        解析 <nav> 标签内的原始文本，返回导航命令字典。
        支持格式：
          goto x y           → {'sub': 'goto', 'x': 3.0, 'y': 4.0}
          goto 地点名         → {'sub': 'goto', 'name': '卧室'}
          init               → {'sub': 'init'}
          save 名称 x y       → {'sub': 'save', 'name': '卧室', 'x': 2.0, 'y': 8.0}
          waypoints x y;x y   → {'sub': 'waypoints', 'points': [(3,4), (5,6)]}
        返回 None 表示解析失败。
        """
        parts = raw.strip().split()
        if not parts:
            return None

        sub_cmd = parts[0].lower()

        if sub_cmd == 'init':
            return {'sub': 'init'}

        elif sub_cmd == 'goto':
            if len(parts) < 2:
                self.get_logger().warning('goto 参数不足')
                return None
            # 判断第二个参数是数字（坐标）还是文字（地点名）
            try:
                x = float(parts[1])
                y = float(parts[2]) if len(parts) > 2 else 0.0
                return {'sub': 'goto', 'x': x, 'y': y}
            except ValueError:
                # 不是数字，当作地点名处理
                name = parts[1]
                return {'sub': 'goto', 'name': name}

        elif sub_cmd == 'save':
            if len(parts) < 3:
                self.get_logger().warning('save 参数不足，需要 名称 x y')
                return None
            name = parts[1]  # parts[0]='save', parts[1]=名称
            try:
                x = float(parts[len(parts) - 2])
                y = float(parts[-1])
                actual_name = ''.join(parts[1:len(parts) - 2])  # 支持多词名称如"我的家"
                if not actual_name:
                    self.get_logger().warning('save 缺少地点名称')
                    return None
                return {'sub': 'save', 'name': actual_name, 'x': x, 'y': y}
            except ValueError:
                self.get_logger().warning(f'save 坐标解析失败: {parts}')
                return None

        elif sub_cmd == 'waypoints':
            # 去掉 'waypoints' 关键字，保留后续原始文本（含分号和空格）
            waypoints_str = raw[len('waypoints'):].strip()
            if not waypoints_str:
                self.get_logger().warning('waypoints 参数不足')
                return None
            points = []
            for segment in waypoints_str.split(';'):
                segment = segment.strip()
                if not segment:
                    continue
                seg_parts = segment.split()
                # 优先尝试坐标解析 (x y)
                if len(seg_parts) >= 2:
                    try:
                        px = float(seg_parts[0])
                        py = float(seg_parts[1])
                        points.append({'type': 'coord', 'x': px, 'y': py})
                        continue
                    except ValueError:
                        pass
                # 坐标解析失败或只有1个词 → 当作地点名
                loc_name = ''.join(seg_parts)
                points.append({'type': 'location', 'name': loc_name})
            if not points:
                self.get_logger().warning('waypoints 未解析到任何有效点')
                return None
            return {'sub': 'waypoints', 'points': points}

        else:
            self.get_logger().warning(f'未知导航子命令: {sub_cmd}')
            return None

    def _execute_nav(self, cmd):
        """
        导航命令分发器，根据子命令调用具体执行方法。
        在独立线程中运行，避免阻塞 ROS spin 主循环。
        """
        thread = threading.Thread(target=self._execute_nav_thread, args=(cmd,), daemon=True)
        thread.start()

    def _execute_nav_thread(self, cmd):
        """在后台线程中实际执行导航命令"""
        sub = cmd['sub']
        try:
            if sub == 'goto':
                self._nav_goto(cmd)
            elif sub == 'init':
                self._nav_init()
            elif sub == 'save':
                self._nav_save_location(cmd)
            elif sub == 'waypoints':
                self._nav_waypoints(cmd)
            else:
                self.get_logger().warning(f'未知导航子命令: {sub}')
        except Exception as e:
            self.get_logger().error(f'导航执行异常: {e}')
            self._call_tts_sync(f'抱歉，导航出错：{e}')

    def _nav_goto(self, cmd):
        """执行 goto 命令：导航到坐标或命名地点"""
        with self._nav_lock:
            if self._nav_busy:
                self._call_tts_sync('正在导航中，请先等一下')
                self.get_logger().warning('导航忙，忽略新 goto 命令')
                return
            self._nav_busy = True

        try:
            # 解析目标坐标
            if 'name' in cmd:
                # 地点名模式：从字典查找坐标
                name = cmd['name']
                if name not in self._named_locations:
                    self._call_tts_sync(f'抱歉，没找到{name}的位置，请先用 save 保存')
                    self.get_logger().warning(f'未找到地点: {name}')
                    return
                x, y = self._named_locations[name]
                self.get_logger().info(f'地点 "{name}" -> ({x}, {y})')
            else:
                # 坐标模式：直接使用
                x, y = cmd['x'], cmd['y']

            self._call_tts_sync(f'好的，前往目标点')
            # 获取当前朝向作为目标 yaw，避免到达后强制旋转到 0°
            current = self.get_current_pose()
            if current is not None:
                rotation_euler = euler_from_quaternion([
                    current.rotation.x, current.rotation.y,
                    current.rotation.z, current.rotation.w])
                target_yaw = rotation_euler[2]
            else:
                target_yaw = 0.0
            target_pose = self.get_pose_by_xyyaw(x, y, target_yaw)
            self.nav_to_pose(target_pose)
        finally:
            with self._nav_lock:
                self._nav_busy = False

    def _nav_init(self):
        """执行 init 命令：用里程计坐标初始化 AMCL 位姿

        读取 /odom 里程计数据，将其作为初始位姿发布到 /initialpose。
        里程计从启动时开始累计，刚启动时接近 (0, 0)，适合用来初始化定位。
        """
        if self._latest_odom is None:
            self._call_tts_sync('抱歉，尚未收到里程计数据，初始化失败')
            self.get_logger().error('导航初始化失败： odom 数据为空')
            return

        odom = self._latest_odom
        x = odom.pose.pose.position.x
        y = odom.pose.pose.position.y
        yaw = euler_from_quaternion([
            odom.pose.pose.orientation.x, odom.pose.pose.orientation.y,
            odom.pose.pose.orientation.z, odom.pose.pose.orientation.w
        ])[2]

        self._call_tts_sync(f'好的，已将位置初始化为({x:.1f}, {y:.1f})')
        pose_msg = PoseWithCovarianceStamped()
        pose_msg.header.frame_id = 'map'
        pose_msg.header.stamp = self.get_clock().now().to_msg()
        pose_msg.pose.pose = self.get_pose_by_xyyaw(x, y, yaw).pose
        self._initialpose_pub.publish(pose_msg)
        self.get_logger().info(f'位姿已用里程计初始化为 ({x:.2f}, {y:.2f}, yaw={yaw:.2f})')

    def _nav_save_location(self, cmd):
        """执行 save 命令：保存/更新命名地点坐标"""
        name = cmd['name']
        x, y = cmd['x'], cmd['y']
        is_new = name not in self._named_locations
        self._named_locations[name] = (x, y)
        self._save_locations_to_file()
        action_str = '已记录' if is_new else '已更新'
        self._call_tts_sync(f'好的，{action_str}{name}位置为({int(x)}, {int(y)})')
        self.get_logger().info(f'地点{action_str}: {name} -> ({x}, {y})')

    def _nav_waypoints(self, cmd):
        """执行 waypoints 命令：多点巡航导航"""
        with self._nav_lock:
            if self._nav_busy:
                self._call_tts_sync('正在导航中，请先等一下')
                return
            self._nav_busy = True

        try:
            # 解析所有目标点（坐标和地名混合）
            targets = []
            for p in cmd['points']:
                if p['type'] == 'coord':
                    targets.append((p['x'], p['y']))
                elif p['type'] == 'location':
                    name = p['name']
                    if name in self._named_locations:
                        targets.append(self._named_locations[name])
                    else:
                        self._call_tts_sync(f'抱歉，没找到{name}的位置')
                        self.get_logger().warning(f'多点巡航未找到地点: {name}')
                        return

            if not targets:
                self._call_tts_sync('没有有效的目标点')
                return

            total = len(targets)
            self._call_tts_sync(f'好的，开始巡航，共{total}个目标点')
            for i, (x, y) in enumerate(targets, 1):
                self.get_logger().info(f'巡航 [{i}/{total}] -> ({x}, {y})')
                self._call_tts_sync(f'前往第{i}个点')
                target_pose = self.get_pose_by_xyyaw(x, y, 0.0)
                self.nav_to_pose(target_pose)
            self._call_tts_sync('巡航完成，全部到达')
        finally:
            with self._nav_lock:
                self._nav_busy = False

    def _format_locations_for_prompt(self):
        """将已保存的地点格式化为 system prompt 文本"""
        if not self._named_locations:
            return '（暂无保存的地点）'
        lines = []
        for name, (x, y) in self._named_locations.items():
            lines.append(f'  {name}: ({x}, {y})')
        return '\n'.join(lines)

    def _load_locations(self):
        """从 JSON 文件加载已保存的命名地点"""
        try:
            if os.path.exists(self._locations_file):
                with open(self._locations_file, 'r') as f:
                    data = json.load(f)
                    # 兼容旧格式：{"卧室": [2.0, 8.0]} 或 {"卧室": {"x": 2.0, "y": 8.0}}
                    for k, v in data.items():
                        if isinstance(v, (list, tuple)):
                            self._named_locations[k] = (float(v[0]), float(v[1]))
                        elif isinstance(v, dict):
                            self._named_locations[k] = (float(v['x']), float(v['y']))
                self.get_logger().info(f'从文件加载了 {len(self._named_locations)} 个地点')
        except Exception as e:
            self.get_logger().warning(f'加载地点文件失败（将使用空字典）: {e}')
            self._named_locations = {}

    def _save_locations_to_file(self):
        """将命名地点持久化到 JSON 文件"""
        try:
            os.makedirs(os.path.dirname(self._locations_file), exist_ok=True)
            with open(self._locations_file, 'w') as f:
                json.dump(
                    {name: list(coords) for name, coords in self._named_locations.items()},
                    f,
                    ensure_ascii=False,
                    indent=2
                )
        except Exception as e:
            self.get_logger().error(f'保存地点文件失败: {e}')

    # ======================== TTS 语音合成 ========================

    def _call_tts(self, text):
        """调用 TTS 服务将文字转为语音播放"""
        if not text or not text.strip():
            return
        if not self.tts_client.service_is_ready():
            self.get_logger().warning('TTS 未就绪，跳过')
            return
        req = Tts.Request()
        req.text = text
        future = self.tts_client.call_async(req)
        future.add_done_callback(self._tts_done)   # 直接绑定回调

    def _tts_done(self, future):
        """TTS 异步调用完成后的回调，检查是否成功"""
        try:
            result = future.result()
            if result.result:
                self.get_logger().info('TTS 播报成功')
            else:
                self.get_logger().warning('TTS 播报失败')
        except Exception as e:
            self.get_logger().error(f'TTS 异常: {e}')


    def nav_to_pose(self, target_pose):
        """导航到指定位姿（线程安全版）

        使用 ActionClient + sleep 轮询替代 BasicNavigator 的
        goToPose / isTaskComplete / getFeedback / getResult（它们内部调用
        spin_until_future_complete，在后台线程会触发 generator already executing）。
        """
        from nav2_msgs.action import NavigateToPose
        from rclpy.action import ActionClient

        # 延迟创建/复用 ActionClient（构造时 Nav2 可能还没启动）
        if not hasattr(self, '_nav_action_client') or self._nav_action_client is None:
            self._nav_action_client = ActionClient(self, NavigateToPose, 'navigate_to_pose')

        # 等待导航 action server 上线
        if not self._nav_action_client.wait_for_server(timeout_sec=10.0):
            self.get_logger().error('Nav2 导航服务不可用（10秒内未检测到 navigate_to_pose server）')
            self._call_tts_sync('抱歉，导航服务未就绪')
            return False

        # 发送导航目标
        goal_msg = NavigateToPose.Goal()
        goal_msg.pose = target_pose
        send_goal_future = self._nav_action_client.send_goal_async(goal_msg)

        # sleep 轮询等待目标被接受（带15秒超时）
        _deadline = time.time() + 15
        while not send_goal_future.done():
            if time.time() > _deadline:
                self.get_logger().error('导航目标接受超时(15s)')
                self._call_tts_sync('抱歉，导航响应超时')
                return False
            time.sleep(0.1)

        goal_handle = send_goal_future.result()
        if not goal_handle.accepted:
            self.get_logger().warning('导航目标被 Nav2 拒绝')
            self._call_tts_sync('抱歉，导航目标无法接受')
            return False

        self.get_logger().info('导航目标已接受，前往目标点...')

        # sleep 轮询等待导航执行完毕
        result_future = goal_handle.get_result_async()
        while not result_future.done():
            time.sleep(0.5)

        # 判断最终结果（action status 码：4=SUCCEEDED, 5=CANCELED, 6=ABORTED）
        result = result_future.result()
        status = result.status
        if status == 4:   # STATUS_SUCCEEDED
            self.get_logger().info('导航结果：成功到达目标点')
            return True
        elif status == 5:  # STATUS_CANCELED
            self.get_logger().warning('导航结果：被取消')
            self._call_tts_sync('导航已被取消')
            return False
        elif status == 6:  # STATUS_ABORTED
            self.get_logger().error('导航结果：失败/中止')
            self._call_tts_sync('抱歉，导航失败')
            return False
        else:
            self.get_logger().error(f'导航结果：未知状态码={status}')
            self._call_tts_sync(f'抱歉，导航异常状态{status}')
            return False

    def get_current_pose(self):
        """
        通过TF获取当前位姿（最多重试30次）
        """
        for _retry in range(30):
            if not rclpy.ok():
                return None
            try:
                tf = self.buffer_.lookup_transform(
                    'map', 'base_footprint', rclpy.time.Time(seconds=0), rclpy.time.Duration(seconds=1))
                transform = tf.transform
                rotation_euler = euler_from_quaternion([
                    transform.rotation.x,
                    transform.rotation.y,
                    transform.rotation.z,
                    transform.rotation.w
                ])
                self.get_logger().info(
                    f'平移:{transform.translation},旋转四元数:{transform.rotation}:旋转欧拉角:{rotation_euler}')
                return transform
            except Exception as e:
                self.get_logger().warning(f'不能够获取坐标变换({_retry+1}/30)，原因: {str(e)}')
        self.get_logger().error('TF 获取位姿失败：已重试30次仍无法获取')
        return None
    
    def get_pose_by_xyyaw(self, x, y, yaw):
        """
        通过 x,y,yaw 合成 PoseStamped
        """
        pose = PoseStamped()
        pose.header.frame_id = 'map'
        pose.pose.position.x = x
        pose.pose.position.y = y
        rotation_quat = quaternion_from_euler(0, 0, yaw)
        pose.pose.orientation.x = rotation_quat[0]
        pose.pose.orientation.y = rotation_quat[1]
        pose.pose.orientation.z = rotation_quat[2]
        pose.pose.orientation.w = rotation_quat[3]
        return pose


# ======================== 主函数入口 ========================

def main(args=None):
    """ROS2 节点标准入口：初始化 → 创建节点 → spin 循环 → 清理退出"""
    rclpy.init(args=args)
    node = LLMChatNode()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        rclpy.shutdown()


if __name__ == '__main__':
    main()